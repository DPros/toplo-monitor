# Copy to .env.local for local dev. In production these live in Vercel env vars
# and (for the scheduled poll) in GitHub Actions secrets.

# --- Database (Neon Postgres) ---
# Use the POOLED connection string for the app/runtime.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET=""
# Google OAuth (Phase 3) — redirect URI: <site>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- SMTP for notifications (reuses your existing toplo-monitor values) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# --- Scheduled poll endpoint ---
# Shared secret the /api/cron/poll route requires; set the same value in the
# GitHub Action that triggers it.
CRON_SECRET=""
